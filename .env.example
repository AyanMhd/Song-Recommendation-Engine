PORT=3001
PYTHON_BIN=python

# PostgreSQL connection string (Neon) — same URL for local dev and production
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional pool / vector search tuning
PG_POOL_MAX=10
HNSW_EF_SEARCH=100
SEARCH_RESULT_LIMIT=10

# Genius API
GENIUS_ACCESS_TOKEN=your_genius_access_token

# MusicBrainz User-Agent metadata
MUSICBRAINZ_APP_NAME=LyricVibeRecommender
MUSICBRAINZ_APP_VERSION=1.0.0
MUSICBRAINZ_CONTACT_EMAIL=you@example.com
